    gap: 18px;
}

.calendar-row {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 12px;
}

.calendar-day-block {
    padding: 16px;
    border-radius: 18px;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    text-align: center;
    transition: transform 0.2s ease, border-color 0.2s ease;
}

.calendar-day-block:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
}

.calendar-day-block.completed {
    background: linear-gradient(135deg, rgba(56,189,248,0.2), rgba(14,165,233,0.32));
    color: #04263f;
    font-weight: 700;
}

.calendar-day-block.active {
    box-shadow: 0 0 0 2px rgba(56,189,248,0.2);
}

.legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
}

.legend span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 8px 12px;
    background: rgba(255,255,255,0.06);
    color: var(--muted);
    font-size: 0.9rem;
}

.legend .marker {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
}

.profile-avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent);
    background: var(--surface-alt);
}

.file-input {
    display: none;
}

.file-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 16px;
    border: 1px dashed var(--border);
    color: var(--accent);
    background: rgba(56,189,248,0.08);
    cursor: pointer;
}

.level-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(56,189,248,0.12);
    color: var(--accent);
    font-weight: 700;
}

.modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.56);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    z-index: 1000;
}

.modal-backdrop.open {
    opacity: 1;
    pointer-events: auto;
}

.modal {
    width: min(100%, 560px);
    background: var(--surface);
    border-radius: 28px;
    padding: 26px;
    transform: translateY(20px);
    transition: transform 0.25s ease;
}

.modal-backdrop.open .modal {
    transform: translateY(0);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
}

.modal-header h3 {
    margin: 0;
}

.toast-wrapper {
    position: fixed;
    right: 24px;
    bottom: 24px;
    display: grid;
    gap: 12px;
    z-index: 1100;
}

.toast {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    border-radius: 16px;
    background: rgba(15,23,42,0.96);
    color: white;
    box-shadow: 0 20px 50px rgba(0,0,0,0.2);
    animation: slideIn 0.3s ease both;
}

.toast.success {
    border-left: 4px solid var(--success);
}

.toast.error {
    border-left: 4px solid var(--danger);
}

.toast.small {
    width: min(100%, 340px);
}

@keyframes slideIn {
    from { transform: translateX(30px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}

.hidden {
    display: none;
}

.view {
    animation: fadeIn 0.35s ease both;
}

.view {
    display: none;
    animation: fadeIn 0.35s ease both;
}

.view.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 1060px) {
    .app-shell { grid-template-columns: 1fr; }
    .sidebar { position: relative; width: 100%; border-right: none; border-bottom: 1px solid var(--border); }
    .main-content { padding: 20px; }
}

@media (max-width: 760px) {
    .topbar { flex-direction: column; align-items: flex-start; }
    .calendar-row { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .daily-group .exercise-row { grid-template-columns: 1fr 1fr; }
    .sidebar button { justify-content: center; }
}
